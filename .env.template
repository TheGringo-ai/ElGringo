# 🚀 AI TEAM PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
AI_PLATFORM_ENV=development
PORT=8080
HOST=0.0.0.0
DEBUG=true
LOG_LEVEL=info
SECRET_KEY=your-super-secret-key-change-this-in-production

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database
DATABASE_URL=postgresql://aiplatform:password@localhost:5432/aiplatform_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aiplatform_db
DATABASE_USER=aiplatform
DATABASE_PASSWORD=secure_password

# Database Pool Settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=5

# =============================================================================
# AI MODEL API KEYS
# =============================================================================
# OpenAI (ChatGPT)
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_ID=your-openai-org-id
OPENAI_MODEL=gpt-4-turbo

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_PROJECT_ID=your-google-project-id
GEMINI_MODEL=gemini-pro

# xAI (Grok)
XAI_API_KEY=your-xai-api-key
GROK_MODEL=grok-beta

# =============================================================================
# CLOUD PROVIDER CONFIGURATION
# =============================================================================
# Google Cloud Platform
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Amazon Web Services
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-west-2
AWS_ACCOUNT_ID=your-aws-account-id

# Microsoft Azure
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================
# Application Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Logging Configuration
LOG_FORMAT=json
LOG_FILE=logs/ai-platform.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=10

# SSL/TLS
SSL_ENABLED=false
SSL_CERT_PATH=certs/cert.pem
SSL_KEY_PATH=certs/key.pem

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_TLS=true

# SendGrid (Alternative)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# FILE STORAGE
# =============================================================================
# Local Storage
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=50MB

# AWS S3
S3_BUCKET_NAME=your-s3-bucket
S3_REGION=us-west-2
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key

# Google Cloud Storage
GCS_BUCKET_NAME=your-gcs-bucket
GCS_PROJECT_ID=your-gcp-project

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Stripe Payment Processing
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# GitHub Integration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# OAuth Configuration
OAUTH_GOOGLE_CLIENT_ID=your-google-oauth-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-oauth-secret
OAUTH_GITHUB_CLIENT_ID=your-github-oauth-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-oauth-secret

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Worker Configuration
WORKERS=4
WORKER_CLASS=uvicorn.workers.UvicornWorker
WORKER_TIMEOUT=3600
KEEP_ALIVE=2

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Request Timeout
REQUEST_TIMEOUT=300
CONNECT_TIMEOUT=60

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_REGISTRATION=true
ENABLE_API_DOCS=true
ENABLE_ADMIN_PANEL=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_WEBSOCKETS=true
ENABLE_RATE_LIMITING=true

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
DEPLOYMENT_TARGET=docker
CONTAINER_REGISTRY=gcr.io/your-project/ai-platform
IMAGE_TAG=latest
HEALTH_CHECK_PATH=/health
READINESS_CHECK_PATH=/ready

# =============================================================================
# AI TEAM CONFIGURATION
# =============================================================================
# AI Model Settings
AI_TEAM_SIZE=5
MAX_CONCURRENT_REQUESTS=10
MODEL_TIMEOUT=300
ENABLE_MODEL_FALLBACK=true

# Application Generation Settings
DEFAULT_TECH_STACK=FastAPI,React,PostgreSQL
MAX_DEPLOYMENT_TIME=1800
ENABLE_AUTO_SCALING=true
DEFAULT_REPLICAS=3

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================
# Development Mode
DEV_MODE=true
AUTO_RELOAD=true
SHOW_SQL_QUERIES=false
MOCK_AI_RESPONSES=false

# Testing
TESTING=false
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/test_db