# =============================================================================
# AI TEAM PLATFORM - ENVIRONMENT SECRETS
# =============================================================================
# Copy to .env and fill in your API keys. Non-secret settings are in config/default.yaml
#
# IMPORTANT: Only secrets go here. Configuration belongs in config/default.yaml
# =============================================================================

# =============================================================================
# AI MODEL API KEYS (Required - at least one)
# =============================================================================
# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (ChatGPT) - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# xAI (Grok) - https://console.x.ai/
XAI_API_KEY=

# =============================================================================
# OPEN-SOURCE MODEL PROVIDERS (Optional)
# =============================================================================
# Groq (fast Llama) - https://console.groq.com/keys
GROQ_API_KEY=

# Together AI - https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Fireworks AI - https://fireworks.ai/api-keys
FIREWORKS_API_KEY=

# =============================================================================
# GOOGLE CLOUD PLATFORM (Required for Firebase/GCP features)
# =============================================================================
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# SECURITY SECRETS
# =============================================================================
# Application secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-this-in-production

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=change-this-jwt-secret

# =============================================================================
# DATABASE (if using PostgreSQL/Redis)
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/aiplatform
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# OPTIONAL SERVICES (uncomment if needed)
# =============================================================================
# AWS credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Stripe payment processing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# SendGrid email
# SENDGRID_API_KEY=

# Sentry error tracking
# SENTRY_DSN=
