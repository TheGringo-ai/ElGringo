#!/usr/bin/env python3
"""
AI Dev Team - Universal CLI
===========================

Quick access to the AI development team from anywhere.

Usage:
    ai ask "How do I fix this error?"
    ai fix                              # Paste error, get solution
    ai review file.py                   # Review code
    ai review --staged                  # Review staged git changes
    ai commit                           # AI-assisted commit message
    ai chat                             # Interactive chat
    ai status                           # Team status
"""

import argparse
import asyncio
import os
import sys
import subprocess

# Add the platform to path
PLATFORM_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, PLATFORM_DIR)

# Load environment
from dotenv import load_dotenv
load_dotenv(os.path.join(PLATFORM_DIR, '.env'))

from ai_dev_team import AIDevTeam
from ai_dev_team.routing import TaskRouter


def get_team():
    """Get or create the AI team"""
    return AIDevTeam(project_name=os.path.basename(os.getcwd()))


async def cmd_ask(args):
    """Ask the team a question"""
    question = ' '.join(args.question)
    if not question:
        print("Usage: ai ask \"your question here\"")
        return

    team = get_team()
    print(f"\n🤔 Asking team: {question}\n")

    response = await team.ask(question)
    print(f"[{response.agent_name}] ({response.confidence:.0%} confidence)\n")
    print(response.content)
    print()


async def cmd_fix(args):
    """Fix an error - paste or pipe error text"""
    print("🔧 AI Error Fixer")
    print("=" * 50)

    # Get error from args, stdin, or prompt
    if args.error:
        error_text = ' '.join(args.error)
    elif not sys.stdin.isatty():
        error_text = sys.stdin.read()
    else:
        print("Paste your error (Ctrl+D when done):\n")
        lines = []
        try:
            while True:
                lines.append(input())
        except EOFError:
            pass
        error_text = '\n'.join(lines)

    if not error_text.strip():
        print("No error provided.")
        return

    team = get_team()

    prompt = f"""Analyze this error and provide a fix:

ERROR:
{error_text}

Please provide:
1. What caused this error (1 sentence)
2. How to fix it (specific code or commands)
3. How to prevent it in the future (1 sentence)

Be concise and practical."""

    print("\n🔍 Analyzing error...\n")
    result = await team.collaborate(prompt, mode="parallel")

    print(f"✅ Solution (from {', '.join(result.participating_agents)}):\n")
    print(result.final_answer)
    print()


async def cmd_review(args):
    """Review code for issues"""
    team = get_team()

    if args.staged:
        # Review staged git changes
        try:
            diff = subprocess.check_output(
                ['git', 'diff', '--cached'],
                text=True
            )
            if not diff:
                print("No staged changes to review.")
                return
            code = f"Git staged changes:\n\n{diff}"
            filename = "staged changes"
        except subprocess.CalledProcessError:
            print("Not a git repository or git not available.")
            return
    elif args.file:
        # Review specific file
        filepath = args.file
        if not os.path.exists(filepath):
            print(f"File not found: {filepath}")
            return
        with open(filepath, 'r') as f:
            code = f.read()
        filename = filepath
    else:
        print("Usage: ai review <file> or ai review --staged")
        return

    print(f"📝 Reviewing: {filename}")
    print("=" * 50)

    result = await team.code_review(
        code=code,
        language=args.lang or "auto",
        focus=["bugs", "security", "performance", "best-practices"]
    )

    print(f"\n✅ Review by {', '.join(result.participating_agents)}:\n")
    print(result.final_answer)
    print()


async def cmd_commit(args):
    """Generate a commit message for staged changes"""
    try:
        # Get staged diff
        diff = subprocess.check_output(
            ['git', 'diff', '--cached', '--stat'],
            text=True
        )
        if not diff:
            print("No staged changes. Use 'git add' first.")
            return

        diff_content = subprocess.check_output(
            ['git', 'diff', '--cached'],
            text=True
        )
    except subprocess.CalledProcessError:
        print("Not a git repository or git not available.")
        return

    team = get_team()

    prompt = f"""Generate a concise git commit message for these changes:

FILES CHANGED:
{diff}

DIFF:
{diff_content[:3000]}

Requirements:
- First line: type(scope): description (max 50 chars)
- Types: feat, fix, docs, style, refactor, test, chore
- Optional body with bullet points if needed
- Be specific about WHAT changed, not just "updated files"

Return ONLY the commit message, nothing else."""

    print("📝 Generating commit message...\n")
    response = await team.ask(prompt)

    message = response.content.strip()
    print(f"Suggested commit message:\n")
    print("-" * 50)
    print(message)
    print("-" * 50)

    # Ask to use it
    print("\nUse this message? [Y/n/e(dit)] ", end="")
    try:
        choice = input().strip().lower()
        if choice in ('', 'y', 'yes'):
            subprocess.run(['git', 'commit', '-m', message])
            print("✅ Committed!")
        elif choice in ('e', 'edit'):
            subprocess.run(['git', 'commit', '-m', message, '-e'])
        else:
            print("Commit cancelled.")
    except KeyboardInterrupt:
        print("\nCancelled.")


async def cmd_chat(args):
    """Interactive chat with the team"""
    team = get_team()

    print("\n🤖 AI Dev Team Chat")
    print("=" * 50)
    print(f"Agents: {', '.join(team.available_agents)}")
    print("Type 'exit' to quit, 'clear' to reset context\n")

    context = []

    while True:
        try:
            user_input = input("You: ").strip()

            if not user_input:
                continue
            if user_input.lower() == 'exit':
                print("Goodbye!")
                break
            if user_input.lower() == 'clear':
                context = []
                print("Context cleared.\n")
                continue

            # Add context from previous exchanges
            full_prompt = user_input
            if context:
                full_prompt = "Previous context:\n" + "\n".join(context[-3:]) + "\n\nNew question: " + user_input

            response = await team.ask(full_prompt)

            print(f"\n[{response.agent_name}]: {response.content}\n")

            # Save to context
            context.append(f"User: {user_input}")
            context.append(f"AI: {response.content[:200]}...")

        except KeyboardInterrupt:
            print("\nGoodbye!")
            break
        except EOFError:
            break


async def cmd_status(args):
    """Show team status"""
    team = get_team()
    status = team.get_team_status()

    print("\n🤖 AI Dev Team Status")
    print("=" * 50)
    print(f"Project: {status['project']}")
    print(f"Agents Online: {status['total_agents']}")
    print(f"Memory: {'✓' if status['memory_enabled'] else '✗'}")
    print(f"Learning: {'✓' if status['learning_enabled'] else '✗'}")

    print("\nAgents:")
    for name, info in status['agents'].items():
        print(f"  [{info['model_type'].upper()}] {name}")
        print(f"       Role: {info['role']}")
        print(f"       Requests: {info['total_requests']}, Success: {info['success_rate']:.0%}")
    print()


def main():
    parser = argparse.ArgumentParser(
        description="AI Dev Team - Universal CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  ask       Ask the team a question
  fix       Analyze and fix an error
  review    Review code for issues
  commit    Generate commit message
  chat      Interactive chat mode
  status    Show team status

Examples:
  ai ask "How do I parse JSON in Python?"
  ai fix "TypeError: cannot unpack non-iterable NoneType"
  ai review app.py --lang python
  ai review --staged
  ai commit
  ai chat
        """
    )

    subparsers = parser.add_subparsers(dest='command', help='Command to run')

    # ask
    ask_parser = subparsers.add_parser('ask', help='Ask a question')
    ask_parser.add_argument('question', nargs='*', help='Your question')

    # fix
    fix_parser = subparsers.add_parser('fix', help='Fix an error')
    fix_parser.add_argument('error', nargs='*', help='Error text (or pipe/paste)')

    # review
    review_parser = subparsers.add_parser('review', help='Review code')
    review_parser.add_argument('file', nargs='?', help='File to review')
    review_parser.add_argument('--staged', action='store_true', help='Review staged git changes')
    review_parser.add_argument('--lang', help='Language (auto-detected if not specified)')

    # commit
    commit_parser = subparsers.add_parser('commit', help='Generate commit message')

    # chat
    chat_parser = subparsers.add_parser('chat', help='Interactive chat')

    # status
    status_parser = subparsers.add_parser('status', help='Show team status')

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return

    # Run the appropriate command
    commands = {
        'ask': cmd_ask,
        'fix': cmd_fix,
        'review': cmd_review,
        'commit': cmd_commit,
        'chat': cmd_chat,
        'status': cmd_status,
    }

    asyncio.run(commands[args.command](args))


if __name__ == '__main__':
    main()
